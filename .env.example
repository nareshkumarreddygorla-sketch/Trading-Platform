# ──────────────────────────────────────────────
# Trading Platform Environment Configuration
# Copy to .env and fill in your values
#
# SECURITY: Generate JWT_SECRET with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────────────

# ── Authentication (REQUIRED) ──
# IMPORTANT: Generate a unique secret. Never use the example value.
JWT_SECRET=CHANGE-ME-run-python3-c-import-secrets-print-secrets-token_hex-32
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE-ME-use-a-strong-password-min-12-chars
AUTH_ADMIN=1

# ── Environment ──
ENV=development
LOG_LEVEL=INFO
# LOG_FORMAT=json  # Set to "json" for structured JSON log output (recommended in production)

# ── Error Tracking (optional) ──
# SENTRY_DSN=

# ── Database (required in production, optional in dev) ──
# DATABASE_URL=postgresql://user:password@localhost:5432/trading
POSTGRES_PASSWORD=CHANGE-ME-use-a-strong-random-password

# ── Redis (optional - in-memory fallback if unset) ──
# REDIS_URL=redis://localhost:6379/0

# ── Market Data ──
# MD_REDIS_URL=redis://localhost:6379/0
# MD_KAFKA_BROKERS=localhost:9092

# ── Angel One Broker (optional) ──
# ANGEL_ONE_API_KEY=
# ANGEL_ONE_CLIENT_ID=
# ANGEL_ONE_PASSWORD=
# ANGEL_ONE_TOTP_SECRET=
# ANGEL_ONE_MARKETDATA_ENABLED=false

# ── CORS (optional - defaults to localhost in dev) ──
# CORS_ORIGINS=https://your-frontend-domain.com
# FRONTEND_URL=https://your-frontend-domain.com

# ── Grafana (Docker Compose) ──
# GRAFANA_PASSWORD=CHANGE-ME-use-a-strong-password

# ── Risk Limits ──
# RISK_MAX_POSITION_PCT=5.0
# RISK_MAX_DAILY_LOSS_PCT=2.0
# RISK_MAX_OPEN_POSITIONS=10
# RISK_CIRCUIT_BREAKER_DRAWDOWN_PCT=5.0

# ── Execution ──
# EXEC_PAPER=true
# PAPER_EXECUTION_MODE=true

# ── API ──
# API_HOST=0.0.0.0
# API_PORT=8000
