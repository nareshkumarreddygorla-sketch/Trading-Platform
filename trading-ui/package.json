{
  "name": "trading-platform-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "cd .. && JWT_SECRET=dev-secret-minimum-32-characters-long PYTHONPATH=. ./venv/bin/uvicorn src.api.app:app --host 0.0.0.0 --port 8000",
    "dev:all": "concurrently -n api,web \"npm run dev:api\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.11.0",
    "lightweight-charts": "^4.1.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.14",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@jest/types": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.47",
    "ts-jest": "^29.4.6",
    "typescript": "^5.6.3"
  }
}
